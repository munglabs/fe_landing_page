---
const { title, subtitle, buttonText, buttonLink } = Astro.props;

const arrowIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>`;
---

<section id="cta" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="relative rounded-2xl bg-gradient-to-br from-mung-600 to-mung-800 p-10 sm:p-16 overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2" />
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full blur-2xl translate-y-1/2 -translate-x-1/2" />

      <div class="relative text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">
          {title}
        </h2>
        <p class="mt-4 text-mung-100 max-w-lg mx-auto">
          {subtitle}
        </p>
        <div class="mt-8">
          <a
            href={buttonLink}
            class="group inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-mung-700 bg-white rounded-lg hover:bg-mung-50 transition-colors duration-200 shadow-sm"
          >
            {buttonText}
            <span class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" set:html={arrowIcon} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
