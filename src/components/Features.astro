---
const features = [
  {
    title: 'AI Research',
    description: 'Exploring machine learning, LLMs, and intelligent systems with practical implementations.',
    icon: 'Cpu',
  },
  {
    title: 'Electronics & IoT',
    description: 'Hands-on work with microcontrollers, sensors, and connected devices.',
    icon: 'Wifi',
  },
  {
    title: 'Software & Tools',
    description: 'Building developer tools, automation scripts, and open-source utilities.',
    icon: 'Code',
  },
  {
    title: 'DIY & Tinkering',
    description: 'Prototyping, 3D printing, and hands-on experiments with new technologies.',
    icon: 'Lightbulb',
  },
  {
    title: 'Research & Notes',
    description: 'Documenting findings, write-ups, and technical deep-dives from our work.',
    icon: 'BookOpen',
  },
  {
    title: 'Content Creation',
    description: 'Sharing what we build through videos, articles, and tutorials.',
    icon: 'Camera',
  },
];

const iconMap: Record<string, string> = {
  Cpu: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>`,
  Wifi: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h.01"/><path d="M2 8.82a15 15 0 0 1 20 0"/><path d="M5 12.859a10 10 0 0 1 14 0"/><path d="M8.5 16.42a5 5 0 0 1 7 0"/></svg>`,
  Code: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  Lightbulb: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`,
  BookOpen: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7"/></svg>`,
  Camera: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`,
};
---

<section id="about" class="py-24 px-6 bg-slate-50/50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-sm font-medium text-mung-600 tracking-wide uppercase">What We Do</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">
        A humble lab, serious work
      </h2>
      <p class="mt-4 text-slate-500 max-w-xl mx-auto">
        Mung means "just" in Javanese. We're just a lab — but what we do inside is anything but casual.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(feature => (
        <div class="group bg-white rounded-xl border border-slate-100 p-6 hover:border-mung-200 hover:shadow-sm transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-mung-50 flex items-center justify-center text-mung-600 group-hover:bg-mung-600 group-hover:text-white transition-colors duration-300">
            <span set:html={iconMap[feature.icon]} />
          </div>
          <h3 class="mt-4 text-base font-semibold text-slate-900">
            {feature.title}
          </h3>
          <p class="mt-2 text-sm text-slate-500 leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
