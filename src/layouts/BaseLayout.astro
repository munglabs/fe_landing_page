---
import '../styles/global.css';

const { title = 'Munglabs' } = Astro.props;
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style>
      body { font-family: 'Inter', system-ui, sans-serif; }

      .prose h1 { font-size: 2rem; font-weight: 700; color: #0f172a; margin-top: 2rem; margin-bottom: 1rem; }
      .prose h2 { font-size: 1.5rem; font-weight: 600; color: #1e293b; margin-top: 1.75rem; margin-bottom: 0.75rem; }
      .prose h3 { font-size: 1.25rem; font-weight: 600; color: #334155; margin-top: 1.5rem; margin-bottom: 0.5rem; }
      .prose p { color: #475569; line-height: 1.75; margin-bottom: 1rem; }
      .prose a { color: #2563eb; text-decoration: underline; text-underline-offset: 2px; }
      .prose a:hover { color: #1d4ed8; }
      .prose code { font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; background: #f1f5f9; padding: 0.125rem 0.375rem; border-radius: 0.25rem; color: #334155; }
      .prose pre { background: #0f172a; color: #e2e8f0; padding: 1rem 1.25rem; border-radius: 0.5rem; overflow-x: auto; margin-bottom: 1rem; }
      .prose pre code { background: none; color: inherit; padding: 0; font-size: 0.875rem; }
      .prose ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1rem; color: #475569; }
      .prose ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1rem; color: #475569; }
      .prose blockquote { border-left: 3px solid #93c5fd; padding-left: 1rem; color: #64748b; font-style: italic; margin-bottom: 1rem; }
      .prose img { border-radius: 0.5rem; margin: 1.5rem 0; }
      .prose hr { border: none; border-top: 1px solid #e2e8f0; margin: 2rem 0; }
    </style>
  </head>
  <body class="min-h-screen bg-white text-slate-900">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-3 focus:py-2 focus:bg-mung-600 focus:text-white focus:rounded">
      Skip to content
    </a>
    <slot />
  </body>
</html>
